# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://chat_demo:chat_demo@localhost:5432/chat_demo

# Ably (Realtime WebSockets)
ABLY_API_KEY=your_ably_api_key

# Anchorbrowser
# API key is required for local dev. In production, it can be derived from the user session.
ANCHORBROWSER_API_KEY=your_api_key
ANCHORBROWSER_API_URL=https://api.anchorbrowser.io
ANCHORBROWSER_DASHBOARD_API_URL=https://app.anchorbrowser.io

# WorkOS Auth
WORKOS_CLIENT_ID=your_workos_client_id
WORKOS_API_KEY=your_workos_api_key
WORKOS_COOKIE_PASSWORD=a_32_character_or_longer_random_string
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# LLM Providers (Claude is default, others optional)
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key

# LinkedIn Task IDs (from Anchorbrowser dashboard — optional)
TASK_ID_LINKEDIN_SEARCH_PEOPLE=
TASK_ID_LINKEDIN_VIEW_PROFILE=
TASK_ID_LINKEDIN_SEND_CONNECTION_REQUEST=
TASK_ID_LINKEDIN_SEND_MESSAGE=
TASK_ID_LINKEDIN_SEARCH_JOBS=
TASK_ID_LINKEDIN_CREATE_POST=
TASK_ID_LINKEDIN_REACT_TO_POST=
TASK_ID_LINKEDIN_COMMENT_ON_POST=
TASK_ID_LINKEDIN_GET_FEED=
TASK_ID_LINKEDIN_GET_NOTIFICATIONS=
